<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".calculatorr">

    <EditText
        android:layout_margin="10dp"
        android:hint="angka 1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/edAngka1"
        />

    <EditText
        android:layout_margin="10dp"
        android:hint="angka 2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/edAngka2"/>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <Button
            android:text="tambah"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:id="@+id/btTambah"
            />

        <Button
            android:text="kurang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:id="@+id/btKurang"/>

        <Button
            android:text="kali"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:id="@+id/btKali"/>
        <Button
            android:text="bagi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:id="@+id/btBagi"/>
    </LinearLayout>

    <TextView
        android:textSize="30sp"
        android:layout_gravity="center"
        android:layout_margin="10dp"
        android:text="hasil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/edHasil"
        />
    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="160dp"
        android:text="Reset"
        android:id="@+id/btResest"
        />
</LinearLayout>
